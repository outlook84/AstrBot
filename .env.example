# ==========================================
# AstrBot 环境配置示例
# ==========================================
# 将此文件复制为 .env 并根据需要修改。
# 注意：在此处设置的变量将覆盖默认配置。
# 程序会自动读取.env文件（通过cli启动时）
# ------------------------------------------
# 核心配置
# ------------------------------------------

# AstrBot 根目录路径。默认：当前工作目录或桌面客户端为 ~/.astrbot(服务器为：/vat/lib/astrbot/<botxxx>/)
# ASTRBOT_ROOT=/path/to/astrbot

# 日志等级。可选值：DEBUG, INFO, WARNING, ERROR, CRITICAL。默认：INFO。
# ASTRBOT_LOG_LEVEL=INFO

# 启用插件热重载。设置为 "1" 启用（开发时有用）。
# ASTRBOT_RELOAD=0

# 禁用统计（上报匿名使用数据）。设置为 "1" 禁用。
ASTRBOT_DISABLE_METRICS=0

# 覆盖 Python 可执行文件路径（用于本地代码执行功能）。
# PYTHON=/usr/bin/python3

# 启用演示模式（可能限制部分功能）。
# DEMO_MODE=False

# 启用测试模式（影响日志和部分行为）。
# TESTING=False

# 标记：是否通过桌面客户端执行（主要用于内部，不过如果需要测试，可以开启）。
# ASTRBOT_DESKTOP_CLIENT=0

# 标记：是否通过 systemd 服务执行。
# ASTRBOT_SYSTEMD=0

# ------------------------------------------
# 管理面板配置
# ------------------------------------------

# 启用或禁用 WebUI 管理面板。默认：True。
ASTRBOT_DASHBOARD_ENABLE=True

# ------------------------------------------
# 网络配置
# ------------------------------------------

# HTTP/HTTPS 代理 URL（例如：http://127.0.0.1:7890）。
# http_proxy=
# https_proxy=

# 不走代理的主机列表（逗号分隔）。
# no_proxy=localhost,127.0.0.1

# ------------------------------------------
# 第三方集成
# ------------------------------------------

# Alibaba DashScope API Key（用于 Rerank 服务）。
# DASHSCOPE_API_KEY=sk-xxxxxxxxxxxx

# Coze 集成
# COZE_API_KEY=
# COZE_BOT_ID=

# 计算机控制相关的数据目录（用于截图/文件存储）。
# BAY_DATA_DIR=

# ------------------------------------------
# 平台特定配置
# ------------------------------------------

# QQ 官方机器人测试模式开关。
# TEST_MODE=off

# ------------------------------------------
# API 配置（若未单独设置则使用对应的 DASHBOARD 值）
# ------------------------------------------

# API 绑定主机（默认使用 ASTRBOT_DASHBOARD_HOST）
ASTRBOT_HOST=0.0.0.0

# API 绑定端口（默认使用 ASTRBOT_DASHBOARD_PORT）
ASTRBOT_PORT=6185

# 是否为 API 启用 SSL（true/false）
ASTRBOT_SSL_ENABLE=false

# API SSL 证书路径（PEM 格式）
ASTRBOT_SSL_CERT=""

# API SSL 私钥路径（PEM 格式）
ASTRBOT_SSL_KEY=""

# API SSL CA 证书链路径（可选）
ASTRBOT_SSL_CA_CERTS=""
